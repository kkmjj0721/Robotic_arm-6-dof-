<?xml version="1.0"?>
<robot
  name="rcm_final_model_proportional_end_modeled_link"
  xmlns:xacro="http://www.ros.org/wiki/xacro"
>
  <xacro:property name="tool_clamp_sleeve_length" value="0.10"/>
  <xacro:property name="tool_clamp_sleeve_start_y" value="-0.03"/>
  <xacro:property name="tool_clamp_sleeve_half_length" value="${tool_clamp_sleeve_length / 2.0}"/>
  <xacro:property name="tool_clamp_sleeve_center_y" value="${tool_clamp_sleeve_start_y - tool_clamp_sleeve_half_length}"/>
  <xacro:property name="tool_clamp_front_y" value="${tool_clamp_sleeve_start_y - tool_clamp_sleeve_length}"/>
  <xacro:property name="tool_clamp_inertial_y" value="-0.05"/>
  <xacro:property name="tool_inner_length" value="0.28"/>
  <xacro:property name="tool_inner_radius" value="0.004"/>
  <xacro:property name="tool_inner_mass" value="0.15"/>
  <xacro:property name="tool_inner_half_length" value="${tool_inner_length / 2.0}"/>
  <xacro:property name="tool_inner_tip_y" value="${-tool_inner_length}"/>
  <xacro:property
    name="tool_inner_inertia_trans"
    value="${tool_inner_mass * (3.0 * tool_inner_radius * tool_inner_radius + tool_inner_length * tool_inner_length) / 12.0}"
  />
  <xacro:property
    name="tool_inner_inertia_axial"
    value="${0.5 * tool_inner_mass * tool_inner_radius * tool_inner_radius}"
  />
  <xacro:property name="modeled_link_length" value="0.32"/>
  <xacro:property name="modeled_link_radius" value="0.0035"/>
  <xacro:property name="modeled_link_pitch_deg" value="30.0"/>
  <xacro:property name="modeled_link_pitch_rad" value="${modeled_link_pitch_deg * 3.141592653589793 / 180.0}"/>
  <xacro:property name="modeled_link_connection_ratio" value="0.25"/>
  <xacro:property name="modeled_link_mass" value="0.03"/>
  <xacro:property name="modeled_link_half_length" value="${modeled_link_length / 2.0}"/>
  <xacro:property name="modeled_link_center_y" value="${(modeled_link_connection_ratio - 0.5) * modeled_link_length}"/>
  <xacro:property name="modeled_link_tip_y" value="${-(1.0 - modeled_link_connection_ratio) * modeled_link_length}"/>
  <xacro:property
    name="modeled_link_inertia_trans"
    value="${modeled_link_mass * (3.0 * modeled_link_radius * modeled_link_radius + modeled_link_length * modeled_link_length) / 12.0}"
  />
  <xacro:property
    name="modeled_link_inertia_axial"
    value="${0.5 * modeled_link_mass * modeled_link_radius * modeled_link_radius}"
  />
  <!--
    Because the local tool axis is aligned with -Y, the visible pitch offset is
    implemented as a fixed-joint rotation about the child X axis.
  -->
  <material name="robot_blue">
    <color rgba="0.13 0.42 0.92 1.0"/>
  </material>
  <material name="joint_gray">
    <color rgba="0.56 0.58 0.62 1.0"/>
  </material>
  <material name="sleeve_gray">
    <color rgba="0.42 0.44 0.48 1.0"/>
  </material>
  <material name="tool_gray">
    <color rgba="0.74 0.74 0.74 1.0"/>
  </material>
  <material name="clamp_black">
    <color rgba="0.16 0.17 0.19 1.0"/>
  </material>
  <material name="tip_red">
    <color rgba="0.88 0.18 0.18 1.0"/>
  </material>

  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.35"/>
      <inertia ixx="0.00018" ixy="0.0" ixz="0.0" iyy="0.00018" iyz="0.0" izz="0.00018"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.03"/>
      </geometry>
      <material name="joint_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.03"/>
      </geometry>
    </collision>
  </link>

  <joint name="q1" type="revolute">
    <parent link="base_link"/>
    <child link="pedestal_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="8.0" velocity="3.0"/>
    <dynamics damping="0.10" friction="0.02"/>
  </joint>

  <link name="pedestal_link">
    <inertial>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <mass value="0.45"/>
      <inertia ixx="0.00045" ixy="0.0" ixz="0.0" iyy="0.00045" iyz="0.0" izz="0.00004"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.014" length="0.30"/>
      </geometry>
      <material name="joint_gray"/>
    </visual>
    <visual>
      <origin xyz="0 0 0.30" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.018"/>
      </geometry>
      <material name="robot_blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.014" length="0.30"/>
      </geometry>
    </collision>
  </link>

  <joint name="q2" type="revolute">
    <parent link="pedestal_link"/>
    <child link="upper_arm_link"/>
    <origin xyz="0 0 0.30" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.91986" upper="1.91986" effort="8.0" velocity="3.0"/>
    <dynamics damping="0.10" friction="0.02"/>
  </joint>

  <link name="upper_arm_link">
    <inertial>
      <origin xyz="0 0 0.13" rpy="0 0 0"/>
      <mass value="0.80"/>
      <inertia ixx="0.00250" ixy="0.0" ixz="0.0" iyy="0.00250" iyz="0.0" izz="0.00008"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.13" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.018" length="0.26"/>
      </geometry>
      <material name="robot_blue"/>
    </visual>
    <visual>
      <origin xyz="0 0 0.26" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.022"/>
      </geometry>
      <material name="robot_blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.13" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.018" length="0.26"/>
      </geometry>
    </collision>
  </link>

  <joint name="q3" type="revolute">
    <parent link="upper_arm_link"/>
    <child link="forearm_link"/>
    <origin xyz="0 0 0.26" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-2.44346" upper="2.44346" effort="6.0" velocity="3.0"/>
    <dynamics damping="0.08" friction="0.02"/>
  </joint>

  <link name="forearm_link">
    <inertial>
      <origin xyz="0 0 0.13" rpy="0 0 0"/>
      <mass value="0.45"/>
      <inertia ixx="0.00055" ixy="0.0" ixz="0.0" iyy="0.00055" iyz="0.0" izz="0.00002"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.13" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.012" length="0.26"/>
      </geometry>
      <material name="robot_blue"/>
    </visual>
    <visual>
      <origin xyz="0 0 0.26" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.014"/>
      </geometry>
      <material name="robot_blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.13" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.012" length="0.26"/>
      </geometry>
    </collision>
  </link>

  <link name="tool_local_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.005"/>
      <inertia ixx="0.000001" ixy="0.0" ixz="0.0" iyy="0.000001" iyz="0.0" izz="0.000001"/>
    </inertial>
  </link>

  <joint name="tool_local_mount" type="fixed">
    <parent link="forearm_link"/>
    <child link="tool_local_link"/>
    <origin xyz="0 0 0.26" rpy="-1.57079632679 0 -1.57079632679"/>
  </joint>

  <link name="tool_yaw_link">
    <inertial>
      <origin xyz="0 -0.010 0" rpy="0 0 0"/>
      <mass value="0.030"/>
      <inertia ixx="0.000010" ixy="0.0" ixz="0.0" iyy="0.000010" iyz="0.0" izz="0.000008"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.005" length="0.03"/>
      </geometry>
      <material name="joint_gray"/>
    </visual>
    <visual>
      <origin xyz="0 -0.014 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.030 0.028 0.020"/>
      </geometry>
      <material name="sleeve_gray"/>
    </visual>
    <collision>
      <origin xyz="0 -0.014 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.030 0.028 0.020"/>
      </geometry>
    </collision>
  </link>

  <joint name="tool_yaw" type="revolute">
    <parent link="tool_local_link"/>
    <child link="tool_yaw_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="0.5" velocity="0.8"/>
    <dynamics damping="0.35" friction="0.18"/>
  </joint>

  <link name="tool_pitch_link">
    <inertial>
      <origin xyz="0 -0.018 0" rpy="0 0 0"/>
      <mass value="0.040"/>
      <inertia ixx="0.000014" ixy="0.0" ixz="0.0" iyy="0.000012" iyz="0.0" izz="0.000010"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 1.57079632679 0"/>
      <geometry>
        <cylinder radius="0.0045" length="0.04"/>
      </geometry>
      <material name="joint_gray"/>
    </visual>
    <visual>
      <origin xyz="0 -0.018 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.024 0.036 0.024"/>
      </geometry>
      <material name="sleeve_gray"/>
    </visual>
    <collision>
      <origin xyz="0 -0.018 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.024 0.036 0.024"/>
      </geometry>
    </collision>
  </link>

  <joint name="tool_pitch" type="revolute">
    <parent link="tool_yaw_link"/>
    <child link="tool_pitch_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="-1 0 0"/>
    <limit lower="-1.57080" upper="1.57080" effort="0.5" velocity="0.8"/>
    <dynamics damping="0.35" friction="0.18"/>
  </joint>

  <link name="tool_clamp_link">
    <inertial>
      <origin xyz="0 ${tool_clamp_inertial_y} 0" rpy="0 0 0"/>
      <mass value="0.100"/>
      <inertia ixx="0.00021" ixy="0.0" ixz="0.0" iyy="0.00021" iyz="0.0" izz="0.00002"/>
    </inertial>
    <visual>
      <origin xyz="0 -0.032 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.022 0.036 0.050"/>
      </geometry>
      <material name="clamp_black"/>
    </visual>
    <visual>
      <origin xyz="0 ${tool_clamp_sleeve_center_y} 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.0095" length="${tool_clamp_sleeve_length}"/>
      </geometry>
      <material name="sleeve_gray"/>
    </visual>
    <visual>
      <origin xyz="0 ${tool_clamp_front_y} 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.009"/>
      </geometry>
      <material name="joint_gray"/>
    </visual>
    <collision>
      <origin xyz="0 -0.032 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.022 0.036 0.050"/>
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 ${tool_clamp_sleeve_center_y} 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.0095" length="${tool_clamp_sleeve_length}"/>
      </geometry>
    </collision>
  </link>

  <joint name="tool_pitch_mount" type="fixed">
    <parent link="tool_pitch_link"/>
    <child link="tool_clamp_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <joint name="tool_fixed_mount" type="fixed">
    <parent link="tool_clamp_link"/>
    <child link="tool_inner_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="tool_inner_link">
    <inertial>
      <origin xyz="0 ${-tool_inner_half_length} 0" rpy="0 0 0"/>
      <mass value="${tool_inner_mass}"/>
      <inertia
        ixx="${tool_inner_inertia_trans}"
        ixy="0.0"
        ixz="0.0"
        iyy="${tool_inner_inertia_axial}"
        iyz="0.0"
        izz="${tool_inner_inertia_trans}"
      />
    </inertial>
    <visual>
      <origin xyz="0 ${-tool_inner_half_length} 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="${tool_inner_radius}" length="${tool_inner_length}"/>
      </geometry>
      <material name="tool_gray"/>
    </visual>
    <visual>
      <origin xyz="0 ${tool_inner_tip_y} 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.010"/>
      </geometry>
      <material name="tip_red"/>
    </visual>
    <collision>
      <origin xyz="0 ${-tool_inner_half_length} 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="${tool_inner_radius}" length="${tool_inner_length}"/>
      </geometry>
    </collision>
  </link>

  <joint name="tool_modeled_link_mount" type="fixed">
    <parent link="tool_inner_link"/>
    <child link="tool_modeled_link"/>
    <origin xyz="0 ${tool_inner_tip_y} 0" rpy="${modeled_link_pitch_rad} 0 0"/>
  </joint>

  <link name="tool_modeled_link">
    <inertial>
      <origin xyz="0 ${modeled_link_center_y} 0" rpy="0 0 0"/>
      <mass value="${modeled_link_mass}"/>
      <inertia
        ixx="${modeled_link_inertia_trans}"
        ixy="0.0"
        ixz="0.0"
        iyy="${modeled_link_inertia_axial}"
        iyz="0.0"
        izz="${modeled_link_inertia_trans}"
      />
    </inertial>
    <visual>
      <origin xyz="0 ${modeled_link_center_y} 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="${modeled_link_radius}" length="${modeled_link_length}"/>
      </geometry>
      <material name="tool_gray"/>
    </visual>
    <collision>
      <origin xyz="0 ${modeled_link_center_y} 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="${modeled_link_radius}" length="${modeled_link_length}"/>
      </geometry>
    </collision>
  </link>
</robot>
