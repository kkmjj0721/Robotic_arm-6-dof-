<mujoco model="rcm_final_position">
  <compiler angle="degree" autolimits="true"/>
  <option timestep="0.001" gravity="0 0 0" integrator="implicitfast" iterations="100" ls_iterations="30"/>
  <statistic center="0 0 0.28" extent="0.80"/>

  <visual>
    <headlight ambient="0.55 0.55 0.55" diffuse="0.35 0.35 0.35" specular="0.15 0.15 0.15"/>
    <rgba haze="0.96 0.97 0.98 1"/>
  </visual>

  <asset>
    <material name="robot_blue" rgba="0.13 0.42 0.92 1"/>
    <material name="joint_gray" rgba="0.56 0.58 0.62 1"/>
    <material name="sleeve_gray" rgba="0.42 0.44 0.48 1"/>
    <material name="tool_gray" rgba="0.74 0.74 0.74 1"/>
    <texture name="grid" type="2d" builtin="checker" rgb1="0.88 0.88 0.88" rgb2="0.94 0.94 0.94" width="256" height="256"/>
    <material name="floor_grid" texture="grid" texrepeat="6 6" reflectance="0.05"/>
  </asset>

  <default>
    <joint limited="true" damping="0.30" armature="0.02" frictionloss="0.01"/>
    <geom condim="3" contype="1" conaffinity="1"/>
  </default>

  <worldbody>
    <light pos="0 0 1.6" dir="0 0 -1"/>
    <geom name="floor" type="plane" pos="0 0 0" size="1.2 1.2 0.1" material="floor_grid"/>

    <body name="pivot_ref" pos="0 0 0.32">
      <site name="pivot_site" type="sphere" pos="0 0 0" size="0.008" rgba="0.92 0.16 0.16 0.35"/>
    </body>

    <body name="arm_root" pos="0 0 0">
      <geom name="base_sphere" type="sphere" pos="0 0 0" size="0.03" mass="0.35" material="joint_gray"/>
      <joint name="q1" type="hinge" axis="0 0 1" range="-180 180"/>

      <geom name="pedestal" type="cylinder" pos="0 0 0.06" size="0.014 0.06" mass="0.20" material="joint_gray"/>

      <body name="shoulder" pos="0 0 0.12">
        <geom name="shoulder_cap" type="sphere" pos="0 0 0" size="0.018" mass="0.04" material="robot_blue"/>
        <joint name="q2" type="hinge" axis="1 0 0" range="-110 110"/>
        <geom name="upper_arm" type="capsule" fromto="0 0 0 0 0 0.12" size="0.018" mass="0.45" material="robot_blue"/>

        <body name="elbow" pos="0 0 0.12">
          <geom name="elbow_cap" type="sphere" pos="0 0 0" size="0.022" mass="0.05" material="robot_blue"/>
          <joint name="q3" type="hinge" axis="1 0 0" range="-140 140"/>
          <geom name="forearm" type="capsule" fromto="0 0 0 0 0 0.12" size="0.012" mass="0.22" material="robot_blue"/>

          <body name="tool_local_body" pos="0 0 0.12" quat="0.5 -0.5 0.5 -0.5">
            <site name="pend_site" type="sphere" pos="0 0 0" size="0.005" rgba="0.20 0.45 0.95 0.25"/>

            <body name="tool_yaw_body" pos="0 0 0">
              <inertial pos="0 0 0" mass="0.001" diaginertia="1e-6 1e-6 1e-6"/>
              <joint name="tool_yaw" type="hinge" axis="0 0 1" range="-180 180" damping="0.16" frictionloss="0"/>

              <body name="tool_pitch_body" pos="0 0 0">
                <inertial pos="0 0 0" mass="0.001" diaginertia="1e-6 1e-6 1e-6"/>
                <joint name="tool_pitch" type="hinge" axis="-1 0 0" range="-90 90" damping="0.16" frictionloss="0"/>

                <body name="tool_sleeve_body" pos="0 0 0" euler="90 0 0">
                  <geom name="tool_ball_joint_shell" type="sphere" pos="0 0 0" size="0.016" mass="0.02" material="joint_gray"/>
                  <geom name="tool_sleeve_geom" type="capsule" fromto="0 0 0 0 0 0.18" size="0.0095" mass="0.10" material="sleeve_gray"/>
                  <geom name="tool_sleeve_front" type="sphere" pos="0 0 0.18" size="0.011" mass="0.01" material="sleeve_gray"/>
                  <site name="tool_tcp" type="sphere" pos="0 0 0.17" size="0.007" rgba="0.14 0.80 0.24 0.35"/>

                  <body name="tool_slider" pos="0 0 0">
                    <joint name="tool_slide" type="slide" axis="0 0 1" range="0 0.15" damping="0.60"/>
                    <geom name="tool_inner" type="capsule" fromto="0 0 0 0 0 0.34" size="0.006" mass="0.12" material="tool_gray"/>
                    <site name="tool_tip" type="sphere" pos="0 0 0.34" size="0.009" rgba="0.88 0.18 0.18 1"/>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <equality>
    <connect name="pivot_tcp_lock" site1="pivot_site" site2="tool_tcp" solref="0.002 1" solimp="0.995 0.999 0.0005"/>
  </equality>

  <actuator>
    <position name="q1_pos" joint="q1" kp="80" kv="18" ctrllimited="true" ctrlrange="-3.14159265 3.14159265" forcelimited="true" forcerange="-18 18"/>
    <position name="q2_pos" joint="q2" kp="90" kv="20" ctrllimited="true" ctrlrange="-1.91986218 1.91986218" forcelimited="true" forcerange="-20 20"/>
    <position name="q3_pos" joint="q3" kp="80" kv="18" ctrllimited="true" ctrlrange="-2.44346095 2.44346095" forcelimited="true" forcerange="-16 16"/>
    <position name="tool_slide_pos" joint="tool_slide" kp="160" kv="24" ctrllimited="true" ctrlrange="0 0.15" forcelimited="true" forcerange="-10 10"/>
  </actuator>

  <keyframe>
    <key name="home" qpos="0 -0.69813170 1.09955743 0 0 0.03" ctrl="0 -0.69813170 1.09955743 0.03"/>
  </keyframe>
</mujoco>
