<mujoco model="soloassist_rcm_mirror">
  <compiler angle="radian" autolimits="true"/>
  <option timestep="0.002" integrator="implicitfast" gravity="0 0 -9.81"/>
  <visual>
    <headlight ambient="0.35 0.35 0.35" diffuse="0.6 0.6 0.6" specular="0.15 0.15 0.15"/>
    <rgba haze="0.15 0.2 0.25 1"/>
  </visual>
  <asset>
    <texture name="grid" type="2d" builtin="checker" width="256" height="256"
             rgb1="0.88 0.89 0.90" rgb2="0.95 0.96 0.97"/>
    <material name="floor_mat" texture="grid" texrepeat="8 8" reflectance="0.1"/>
    <material name="shell_white" rgba="0.96 0.96 0.98 1"/>
    <material name="carbon_black" rgba="0.12 0.12 0.12 1"/>
    <material name="metal_gray" rgba="0.62 0.64 0.68 1"/>
    <material name="scope_black" rgba="0.08 0.08 0.1 1"/>
    <material name="pivot_red" rgba="0.9 0.2 0.2 1"/>
  </asset>

  <worldbody>
    <geom name="floor" type="plane" size="1.5 1.5 0.1" material="floor_mat"/>
    <light name="room_light" pos="0 0 2.5" dir="0 0 -1"/>

    <body name="pivot_marker" mocap="true" pos="0 0 0.5">
      <geom name="pivot_geom" type="sphere" size="0.01" rgba="0.9 0.2 0.2 0.8" contype="0" conaffinity="0"/>
      <site name="pivot_site" type="sphere" size="0.005" rgba="0.9 0.2 0.2 1"/>
    </body>

    <body name="base_mount" pos="0 0 0">
      <inertial pos="0 0 0.11" mass="4.8" diaginertia="0.045 0.045 0.020"/>
      <geom type="cylinder" pos="0 0 0.11" size="0.08 0.11" material="metal_gray"/>
      <geom type="box" pos="0 0 0.03" size="0.11 0.11 0.03" material="carbon_black"/>

      <body name="shoulder_link" pos="0 0 0.22">
        <joint name="axis_1" type="hinge" axis="0 0 1" range="-3.14159265359 3.14159265359"
               damping="2.0" frictionloss="0.15"/>
        <inertial pos="0 0 0.238" mass="2.4" diaginertia="0.019 0.019 0.0045"/>
        <geom type="cylinder" pos="0 0 0.238" size="0.032 0.238" material="shell_white"/>

        <body name="upper_cantilever_link" pos="-0.03 0 0.476">
          <joint name="axis_2" type="hinge" axis="0 1 0" range="-3.14159265359 3.14159265359"
                 damping="3.5" frictionloss="0.2"/>
          <inertial pos="0 0 0.1645" mass="1.7" diaginertia="0.015769 0.015769 0.000666"/>
          <geom type="cylinder" pos="0 0 0.1645" size="0.028 0.1645" material="shell_white"/>
          <geom type="cylinder" pos="0.018 0 0.1645" size="0.012 0.150" material="carbon_black"/>
          <geom type="cylinder" pos="0 0 0.312" size="0.040 0.014" material="metal_gray"/>

          <body name="elbow_link" pos="0 0 0.329">
            <joint name="axis_3" type="hinge" axis="0 1 0" range="-3.14159265359 3.14159265359"
                   damping="2.8" frictionloss="0.15"/>
            <inertial pos="0 0 0.0675" mass="0.55" diaginertia="0.000912 0.000912 0.000248"/>
            <geom type="cylinder" pos="0 0 0.0675" size="0.03 0.0675" material="carbon_black"/>
            <geom type="sphere" pos="0 0 0.02" size="0.032" material="metal_gray"/>

            <body name="distal_indexed_link" pos="0 0 0.135">
              <joint name="axis_4_manual_index" type="hinge" axis="0 0 1" range="-3.14159265359 3.14159265359"
                     damping="12.0" frictionloss="8.0"/>
              <inertial pos="0 0 0.0475" mass="0.30" diaginertia="0.000239 0.000239 0.000049"/>
              <geom type="cylinder" pos="0 0 0.0475" size="0.018 0.0475" material="scope_black"/>
              <geom type="cylinder" pos="0 0 0.01" size="0.025 0.01" material="metal_gray"/>
              <site name="gimbal_base_site" pos="0 0 0.095" size="0.006" rgba="0.2 0.7 0.2 1"/>

              <body name="gimbal_outer_link" pos="0 0 0.095">
                <joint name="axis_5_gimbal_yaw" type="hinge" axis="0 0 1" range="-3.14159265359 3.14159265359"
                       damping="0.08" frictionloss="0.01"/>
                <inertial pos="0 0 0" mass="0.18" diaginertia="0.00003 0.00003 0.000044"/>
                <geom type="cylinder" pos="0 0 0" size="0.022 0.012" material="metal_gray"/>
                <geom type="cylinder" pos="0 0 -0.018" size="0.010 0.008" material="metal_gray"/>

                <body name="scope_frame">
                  <joint name="axis_6_gimbal_pitch" type="hinge" axis="1 0 0" range="-1.90 1.90"
                         damping="0.08" frictionloss="0.01"/>
                  <inertial pos="0 0 0.22" mass="0.77" diaginertia="0.00363 0.00363 0.00003"/>
                  <geom type="capsule" fromto="0 0 0 0 0 0.14" size="0.010" material="metal_gray"/>
                  <geom type="capsule" fromto="0 0 0.12 0 0 0.68" size="0.006" material="scope_black"/>
                  <geom type="cylinder" pos="0 0 0.02" size="0.018 0.016" material="metal_gray"/>
                  <site name="shaft_tip_site" pos="0 0 0.68" size="0.006" rgba="0.2 0.4 0.9 1"/>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <position name="act_axis_1" joint="axis_1" kp="420" kv="28" ctrlrange="-3.14159265359 3.14159265359"/>
    <position name="act_axis_2" joint="axis_2" kp="460" kv="30" ctrlrange="-3.14159265359 3.14159265359"/>
    <position name="act_axis_3" joint="axis_3" kp="400" kv="28" ctrlrange="-3.14159265359 3.14159265359"/>
    <position name="act_axis_4_manual_index" joint="axis_4_manual_index" kp="500" kv="28"
              ctrlrange="-3.14159265359 3.14159265359"/>
    <position name="act_axis_5_gimbal_yaw" joint="axis_5_gimbal_yaw" kp="220" kv="18"
              ctrlrange="-3.14159265359 3.14159265359"/>
    <position name="act_axis_6_gimbal_pitch" joint="axis_6_gimbal_pitch" kp="220" kv="18"
              ctrlrange="-1.90 1.90"/>
  </actuator>
</mujoco>