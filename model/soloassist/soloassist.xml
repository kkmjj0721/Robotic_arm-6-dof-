<mujoco model="soloassist">
  <compiler angle="radian" autolimits="true"/>
  <option timestep="0.002" integrator="implicitfast" gravity="0 0 -9.81"/>

  <visual>
    <headlight ambient="0.35 0.35 0.35" diffuse="0.65 0.65 0.65" specular="0.2 0.2 0.2"/>
    <rgba haze="0.15 0.2 0.25 1"/>
  </visual>

  <asset>
    <texture name="grid" type="2d" builtin="checker" width="256" height="256"
             rgb1="0.88 0.89 0.90" rgb2="0.95 0.96 0.97"/>
    <material name="floor_mat" texture="grid" texrepeat="8 8" reflectance="0.08"/>
    <material name="shell_white" rgba="0.95 0.95 0.96 1"/>
    <material name="carbon_black" rgba="0.18 0.20 0.21 1"/>
    <material name="base_blue" rgba="0.05 0.14 0.20 1"/>
    <material name="accent_red" rgba="0.78 0.13 0.12 1"/>
    <material name="metal_gray" rgba="0.62 0.64 0.67 1"/>
    <material name="scope_black" rgba="0.09 0.10 0.11 1"/>
  </asset>

  <default>
    <joint damping="0" frictionloss="0"/>
    <default class="visual">
      <geom type="box" group="2" contype="0" conaffinity="0"/>
    </default>
    <default class="collision">
      <geom type="box" group="3" rgba="0 0 0 0"/>
    </default>
  </default>

  <contact>
    <exclude body1="base_mount" body2="shoulder_link"/>
    <exclude body1="shoulder_link" body2="upper_cantilever_link"/>
    <exclude body1="upper_cantilever_link" body2="elbow_link"/>
    <exclude body1="elbow_link" body2="distal_indexed_link"/>
    <exclude body1="distal_indexed_link" body2="gimbal_outer_link"/>
    <exclude body1="gimbal_outer_link" body2="scope_shaft_link"/>
    <exclude body1="scope_shaft_link" body2="scope_tool_link"/>
    <exclude body1="scope_tool_link" body2="instrument_link"/>
  </contact>

  <worldbody>
    <geom name="floor" type="plane" size="2 2 0.1" material="floor_mat"/>
    <light name="ceiling_light" pos="0 0 2.5" dir="0 0 -1"/>
    <camera name="overview" pos="1.2 -1.3 0.9" xyaxes="0.73 0.68 0 -0.28 0.30 0.91"/>

    <body name="pivot_marker" mocap="true" pos="0 0 0.5">
      <geom name="pivot_geom" type="sphere" size="0.01" rgba="0.90 0.20 0.20 0.75" contype="0" conaffinity="0"/>
      <site name="pivot_site" type="sphere" size="0.005" rgba="0.90 0.20 0.20 1"/>
    </body>

    <body name="base_mount" pos="0 0 0">
      <inertial pos="0 0 0.11" mass="5.50" diaginertia="0.060995 0.034966 0.051595"/>

      <geom name="base_mount_visual_1" class="visual" pos="0 0 0.09" size="0.0835 0.1455 0.09"
            material="base_blue"/>
      <geom name="base_mount_visual_2" class="visual" type="cylinder" pos="0 0 0.23" size="0.055 0.11"
            material="shell_white"/>
      <geom name="base_mount_visual_3" class="visual" pos="0.055 -0.08 0.09" size="0.025 0.035 0.045"
            material="metal_gray"/>
      <geom name="base_mount_collision_1" class="collision" pos="0 0 0.09" size="0.0835 0.1455 0.09"/>
      <geom name="base_mount_collision_2" class="collision" type="cylinder" pos="0 0 0.23" size="0.055 0.11"/>

      <body name="shoulder_link" pos="0 0 0.22">
        <joint name="axis_1" type="hinge" axis="0 0 1" range="-3.14159265359 3.14159265359"
               damping="2.0" frictionloss="0.15"/>
        <inertial pos="-0.015 0 0.238" mass="2.60" diaginertia="0.050408 0.050408 0.001331"/>

        <geom name="shoulder_link_visual_1" class="visual" type="cylinder" pos="-0.015 0 0.238"
              size="0.032 0.2385" material="shell_white"/>
        <geom name="shoulder_link_visual_2" class="visual" type="cylinder" pos="0.010 0 0.248"
              size="0.014 0.21" material="carbon_black"/>
        <geom name="shoulder_link_visual_3" class="visual" type="sphere" pos="-0.055 0 0.28"
              size="0.018" material="accent_red"/>
        <geom name="shoulder_link_collision_1" class="collision" type="cylinder" pos="-0.015 0 0.238"
              size="0.032 0.2385"/>

        <body name="upper_cantilever_link" pos="-0.03 0 0.476">
          <joint name="axis_2" type="hinge" axis="0 1 0" range="-3.14159265359 3.14159265359"
                 damping="3.5" frictionloss="0.20"/>
          <inertial pos="0 0 0.1645" mass="1.70" diaginertia="0.015769 0.015769 0.000666"/>

          <geom name="upper_cantilever_link_visual_1" class="visual" type="cylinder" pos="0 0 0.1645"
                size="0.028 0.1645" material="shell_white"/>
          <geom name="upper_cantilever_link_visual_2" class="visual" type="cylinder" pos="0.018 0 0.1645"
                size="0.012 0.15" material="carbon_black"/>
          <geom name="upper_cantilever_link_visual_3" class="visual" type="cylinder" pos="0 0 0.312"
                size="0.040 0.014" material="metal_gray"/>
          <geom name="upper_cantilever_link_collision_1" class="collision" type="cylinder" pos="0 0 0.1645"
                size="0.028 0.1645"/>

          <body name="elbow_link" pos="0 0 0.329">
            <joint name="axis_3" type="hinge" axis="0 1 0" range="-3.14159265359 3.14159265359"
                   damping="2.8" frictionloss="0.15"/>
            <inertial pos="0 0 0.0675" mass="0.55" diaginertia="0.000912 0.000912 0.000248"/>

            <geom name="elbow_link_visual_1" class="visual" type="cylinder" pos="0 0 0.0675"
                  size="0.030 0.0675" material="carbon_black"/>
            <geom name="elbow_link_visual_2" class="visual" type="sphere" pos="0 0 0.020"
                  size="0.032" material="metal_gray"/>
            <geom name="elbow_link_collision_1" class="collision" type="cylinder" pos="0 0 0.0675"
                  size="0.030 0.0675"/>

            <body name="distal_indexed_link" pos="0 0 0.135">
              <joint name="axis_4_manual_index" type="hinge" axis="0 0 1"
                     range="-3.14159265359 3.14159265359" damping="12.0" frictionloss="8.0"/>
              <inertial pos="0 0 0.0475" mass="0.30" diaginertia="0.000239 0.000239 0.000049"/>
              <site name="gimbal_base_site" pos="0 0 0.095" size="0.004" rgba="0.20 0.75 0.25 1"/>

              <geom name="distal_indexed_link_visual_1" class="visual" type="cylinder" pos="0 0 0.0475"
                    size="0.018 0.0475" material="scope_black"/>
              <geom name="distal_indexed_link_visual_2" class="visual" type="cylinder" pos="0 0 0.010"
                    size="0.025 0.010" material="metal_gray"/>
              <geom name="distal_indexed_link_collision_1" class="collision" type="cylinder" pos="0 0 0.0475"
                    size="0.018 0.0475"/>

              <body name="gimbal_outer_link" pos="0 0 0.095">
                <joint name="axis_5_gimbal_yaw" type="hinge" axis="0 0 1"
                       range="-3.14159265359 3.14159265359" damping="0.08" frictionloss="0.01"/>
                <inertial pos="0 0 0" mass="0.18" diaginertia="0.000030 0.000030 0.000044"/>

                <geom name="gimbal_outer_link_visual_1" class="visual" type="cylinder" pos="0 0 0"
                      size="0.022 0.012" material="metal_gray"/>
                <geom name="gimbal_outer_link_visual_2" class="visual" type="cylinder" pos="0 0 -0.018"
                      size="0.010 0.008" material="metal_gray"/>
                <geom name="gimbal_outer_link_collision_1" class="collision" type="cylinder" pos="0 0 0"
                      size="0.022 0.012"/>
                <geom name="gimbal_outer_link_collision_2" class="collision" type="cylinder" pos="0 0 -0.018"
                      size="0.010 0.008"/>

                <body name="scope_shaft_link" pos="0 0 0">
                  <inertial pos="0 0 0.08" mass="0.20" diaginertia="0.000430 0.000430 0.000010"/>

                  <geom name="scope_shaft_link_visual_1" class="visual" type="cylinder" pos="0 0 0.04"
                        size="0.010 0.04" material="metal_gray"/>
                  <geom name="scope_shaft_link_visual_2" class="visual" type="cylinder" pos="0.0225 0 0.1190"
                        euler="0 0.5236 0" size="0.010 0.045" material="metal_gray"/>
                  <geom name="scope_shaft_link_collision_1" class="collision" type="cylinder" pos="0 0 0.04"
                        size="0.010 0.04"/>

                  <body name="scope_tool_link" pos="0.045 0 0.1579" euler="0 0.5236 0">
                    <inertial pos="0 0 0.14" mass="0.47" diaginertia="0.003100 0.003100 0.000020"/>

                    <geom name="scope_tool_link_visual_1" class="visual" type="cylinder" pos="0 0 0"
                          euler="0 1.57079632679 0" size="0.018 0.016" material="metal_gray"/>
                    <geom name="scope_tool_link_visual_2" class="visual" type="cylinder" pos="0 0 0"
                          size="0.012 0.010" material="metal_gray"/>
                    <geom name="scope_tool_link_visual_3" class="visual" type="cylinder" pos="0 0 0.14"
                          size="0.006 0.14" material="scope_black"/>
                    <geom name="scope_tool_link_collision_1" class="collision" type="cylinder" pos="0 0 0"
                          euler="0 1.57079632679 0" size="0.018 0.016"/>
                    <geom name="scope_tool_link_collision_2" class="collision" type="cylinder" pos="0 0 0.14"
                          size="0.006 0.14"/>

                    <body name="instrument_link" pos="0 0 0.280">
                      <joint name="axis_6_gimbal_pitch" type="hinge" axis="1 0 0" range="-1.90 1.90"
                             damping="0.08" frictionloss="0.01"/>
                      <inertial pos="0 0 0.05" mass="0.10" diaginertia="0.0001 0.0001 0.00001"/>
                      <site name="tool_base_site" pos="0 0 0" size="0.004" rgba="0.25 0.85 0.25 1"/>
                      <site name="shaft_axis_site" pos="0 0 0.12" size="0.0035" rgba="0.20 0.60 0.95 1"/>
                      <site name="shaft_tip_site" pos="0 0 0.25" size="0.0045" rgba="0.20 0.40 0.95 1"/>

                      <geom name="instrument_link_visual_1" class="visual" type="cylinder" pos="0 0 0.05"
                            size="0.004 0.20" material="metal_gray"/>
                    </body>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <position name="act_axis_1" joint="axis_1" kp="900" dampratio="1.1"
              ctrlrange="-3.14159265359 3.14159265359"/>
    <position name="act_axis_2" joint="axis_2" kp="1200" dampratio="1.1"
              ctrlrange="-3.14159265359 3.14159265359"/>
    <position name="act_axis_3" joint="axis_3" kp="800" dampratio="1.1"
              ctrlrange="-3.14159265359 3.14159265359"/>
    <position name="act_axis_4_manual_index" joint="axis_4_manual_index" kp="300" dampratio="1.1"
              ctrlrange="-3.14159265359 3.14159265359"/>
    <position name="act_axis_5_gimbal_yaw" joint="axis_5_gimbal_yaw" kp="500" dampratio="1.1"
              ctrlrange="-3.14159265359 3.14159265359"/>
    <position name="act_axis_6_gimbal_pitch" joint="axis_6_gimbal_pitch" kp="500" dampratio="1.1"
              ctrlrange="-1.90 1.90"/>
  </actuator>

  <keyframe>
    <key name="home" qpos="0 0 0 0 0 0" ctrl="0 0 0 0 0 0"/>
  </keyframe>
</mujoco>
