<?xml version="1.0"?>
<robot name="soloassist_ii">
  <material name="shell_white">
    <color rgba="0.95 0.95 0.96 1.0"/>
  </material>
  <material name="carbon_black">
    <color rgba="0.18 0.20 0.21 1.0"/>
  </material>
  <material name="base_blue">
    <color rgba="0.05 0.14 0.20 1.0"/>
  </material>
  <material name="accent_red">
    <color rgba="0.78 0.13 0.12 1.0"/>
  </material>
  <material name="metal_gray">
    <color rgba="0.62 0.64 0.67 1.0"/>
  </material>
  <material name="scope_black">
    <color rgba="0.09 0.10 0.11 1.0"/>
  </material>

  <link name="base_mount">
    <inertial>
      <origin xyz="0 0 0.11" rpy="0 0 0"/>
      <mass value="5.50"/>
      <inertia ixx="0.060995" ixy="0" ixz="0" iyy="0.034966" iyz="0" izz="0.051595"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.09" rpy="0 0 0"/>
      <geometry>
        <box size="0.167 0.291 0.180"/>
      </geometry>
      <material name="base_blue"/>
    </visual>
    <visual>
      <origin xyz="0 0 0.23" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.055" length="0.220"/>
      </geometry>
      <material name="shell_white"/>
    </visual>
    <visual>
      <origin xyz="0.055 -0.08 0.09" rpy="0 0 0"/>
      <geometry>
        <box size="0.050 0.070 0.090"/>
      </geometry>
      <material name="metal_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.09" rpy="0 0 0"/>
      <geometry>
        <box size="0.167 0.291 0.180"/>
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.23" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.055" length="0.220"/>
      </geometry>
    </collision>
  </link>

  <link name="shoulder_link">
    <inertial>
      <origin xyz="-0.015 0 0.238" rpy="0 0 0"/>
      <mass value="2.60"/>
      <inertia ixx="0.050408" ixy="0" ixz="0" iyy="0.050408" iyz="0" izz="0.001331"/>
    </inertial>
    <visual>
      <origin xyz="-0.015 0 0.238" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.032" length="0.477"/>
      </geometry>
      <material name="shell_white"/>
    </visual>
    <visual>
      <origin xyz="0.010 0 0.248" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.014" length="0.420"/>
      </geometry>
      <material name="carbon_black"/>
    </visual>
    <visual>
      <origin xyz="-0.055 0 0.28" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.018"/>
      </geometry>
      <material name="accent_red"/>
    </visual>
    <collision>
      <origin xyz="-0.015 0 0.238" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.032" length="0.477"/>
      </geometry>
    </collision>
  </link>

  <joint name="axis_1" type="revolute">
    <parent link="base_mount"/>
    <child link="shoulder_link"/>
    <origin xyz="0 0 0.22" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159265359" upper="3.14159265359" effort="30" velocity="1.8"/>
    <dynamics damping="2.0" friction="0.15"/>
  </joint>

  <link name="upper_cantilever_link">
    <inertial>
      <origin xyz="0 0 0.1645" rpy="0 0 0"/>
      <mass value="1.70"/>
      <inertia ixx="0.015769" ixy="0" ixz="0" iyy="0.015769" iyz="0" izz="0.000666"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.1645" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.028" length="0.329"/>
      </geometry>
      <material name="shell_white"/>
    </visual>
    <visual>
      <origin xyz="0.018 0 0.1645" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.012" length="0.300"/>
      </geometry>
      <material name="carbon_black"/>
    </visual>
    <visual>
      <origin xyz="0 0 0.312" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.040" length="0.028"/>
      </geometry>
      <material name="metal_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.1645" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.028" length="0.329"/>
      </geometry>
    </collision>
  </link>

  <joint name="axis_2" type="revolute">
    <parent link="shoulder_link"/>
    <child link="upper_cantilever_link"/>
    <origin xyz="-0.030 0 0.476" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14159265359" upper="3.14159265359" effort="35" velocity="1.6"/>
    <dynamics damping="3.5" friction="0.20"/>
  </joint>

  <link name="elbow_link">
    <inertial>
      <origin xyz="0 0 0.0675" rpy="0 0 0"/>
      <mass value="0.55"/>
      <inertia ixx="0.000912" ixy="0" ixz="0" iyy="0.000912" iyz="0" izz="0.000248"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.0675" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.030" length="0.135"/>
      </geometry>
      <material name="carbon_black"/>
    </visual>
    <visual>
      <origin xyz="0 0 0.020" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.032"/>
      </geometry>
      <material name="metal_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.0675" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.030" length="0.135"/>
      </geometry>
    </collision>
  </link>

  <joint name="axis_3" type="revolute">
    <parent link="upper_cantilever_link"/>
    <child link="elbow_link"/>
    <origin xyz="0 0 0.329" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14159265359" upper="3.14159265359" effort="18" velocity="1.8"/>
    <dynamics damping="2.8" friction="0.15"/>
  </joint>

  <link name="distal_indexed_link">
    <inertial>
      <origin xyz="0 0 0.0475" rpy="0 0 0"/>
      <mass value="0.30"/>
      <inertia ixx="0.000239" ixy="0" ixz="0" iyy="0.000239" iyz="0" izz="0.000049"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.0475" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.018" length="0.095"/>
      </geometry>
      <material name="scope_black"/>
    </visual>
    <visual>
      <origin xyz="0 0 0.010" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.020"/>
      </geometry>
      <material name="metal_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.0475" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.018" length="0.095"/>
      </geometry>
    </collision>
  </link>

  <joint name="axis_4_manual_index" type="revolute">
    <parent link="elbow_link"/>
    <child link="distal_indexed_link"/>
    <origin xyz="0 0 0.135" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159265359" upper="3.14159265359" effort="4" velocity="1.0"/>
    <dynamics damping="12.0" friction="8.0"/>
  </joint>

  <link name="gimbal_outer_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.18"/>
      <inertia ixx="0.000030" ixy="0" ixz="0" iyy="0.000030" iyz="0" izz="0.000044"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.022" length="0.024"/>
      </geometry>
      <material name="metal_gray"/>
    </visual>
    <visual>
      <origin xyz="0 0 -0.018" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.010" length="0.016"/>
      </geometry>
      <material name="metal_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.022" length="0.024"/>
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 -0.018" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.010" length="0.016"/>
      </geometry>
    </collision>
  </link>

  <joint name="axis_5_gimbal_yaw" type="revolute">
    <parent link="distal_indexed_link"/>
    <child link="gimbal_outer_link"/>
    <origin xyz="0 0 0.095" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159265359" upper="3.14159265359" effort="2" velocity="2.5"/>
    <dynamics damping="0.08" friction="0.01"/>
  </joint>

  <link name="scope_shaft_link">
    <inertial>
      <origin xyz="0 0 0.08" rpy="0 0 0"/>
      <mass value="0.20"/>
      <inertia ixx="0.000430" ixy="0" ixz="0" iyy="0.000430" iyz="0" izz="0.000010"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.010" length="0.080"/>
      </geometry>
      <material name="metal_gray"/>
    </visual>
    <visual>
      <origin xyz="0.0225 0 0.1190" rpy="0 0.5236 0"/>
      <geometry>
        <cylinder radius="0.010" length="0.090"/>
      </geometry>
      <material name="metal_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.010" length="0.080"/>
      </geometry>
    </collision>
  </link>

  <joint name="axis_6_gimbal_pitch" type="revolute">
    <parent link="scope_shaft_link"/>
    <child link="scope_tool_link"/>
    <origin xyz="0 0 0.160" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.90" upper="1.90" effort="2" velocity="2.5"/>
    <dynamics damping="0.08" friction="0.01"/>
  </joint>

  <joint name="scope_mount" type="fixed">
    <parent link="gimbal_outer_link"/>
    <child link="scope_shaft_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <joint name="scope_tool_mount" type="fixed">
    <parent link="scope_shaft_link"/>
    <child link="scope_tool_link"/>
    <origin xyz="0.045 0 0.1579" rpy="0 0.5236 0"/> 
  </joint>

  <link name="scope_tool_link">
    <inertial>
      <origin xyz="0 0 0.14" rpy="0 0 0"/>
      <mass value="0.47"/>
      <inertia ixx="0.003100" ixy="0" ixz="0" iyy="0.003100" iyz="0" izz="0.000020"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 1.57079632679 0"/>
      <geometry>
        <cylinder radius="0.018" length="0.032"/>
      </geometry>
      <material name="metal_gray"/>
    </visual>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.012" length="0.020"/>
      </geometry>
      <material name="metal_gray"/>
    </visual>
    <visual>
      <origin xyz="0 0 0.14" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.006" length="0.280"/>
      </geometry>
      <material name="scope_black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 1.57079632679 0"/>
      <geometry>
        <cylinder radius="0.018" length="0.032"/>
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0.14" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.006" length="0.280"/>
      </geometry>
    </collision>
  </link>

  <joint name="axis_6_gimbal_pitch" type="revolute">
    <parent link="scope_tool_link"/>
    <child link="instrument_link"/>
    <origin xyz="0 0 0.280" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.90" upper="1.90" effort="2" velocity="2.5"/>
    <dynamics damping="0.08" friction="0.01"/>
  </joint>

  <link name="instrument_link">
    <inertial>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <mass value="0.10"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.00001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.004" length="0.400"/>
      </geometry>
      <material name="metal_gray"/>
    </visual>
  </link>
</robot>
